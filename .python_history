from pymavlink import mavutil

master = mavutil.mavlink_connection('/dev/ttyAMA0', baud=921600)

while True:
    msg = master.recv_match(blocking=True, timeout=1)
    print(msg)
    
msg = master.recv_match(type='ATTITUDE', blocking=True)
print(msg.roll, msg.pitch, msg.yaw)
msg = master.recv_match(type='GPS_RAW_INT', blocking=True)
print(msg.lat/1e7, msg.lon/1e7)
print(master.flightmode)
print(master.motors_armed())
master.wait_heartbeat()

print("System ID:", master.target_system)
print("Component ID:", master.target_component)
print("Mode:", master.flightmode)
print("Armed:", master.motors_armed())
nano test_mav.py
exit()
